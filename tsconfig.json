{
  "compilerOptions": {
    "strict": true,
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "emitDecoratorMetadata": false, // required
    "experimentalDecorators": true, // required
    "esModuleInterop": true, // required
    "importHelpers": true // required
  },
  "include": ["src"]
}
